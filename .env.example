# Development Settings
FLASK_ENV=development
FLASK_DEBUG=True
# Example: SECRET_KEY=3f74c0f4a1f84c7d9d6f7e6c8f6c9e0a5d...
SECRET_KEY=replace-with-a-long-random-secret-key
# Set to True only when behind a trusted reverse proxy that sets X-Forwarded-For.
TRUST_PROXY_HEADERS=False

# Database
# Uncomment to use PostgreSQL instead of SQLite
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost:5432/farm_management

# Email Configuration (optional)
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-password

# AI Assistant (optional, for free-tier Gemini)
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-5.4-mini
